{
    "name": "filipeseabra/fastcgi-cache-for-ploi",
    "description": "Automatically flush a Ploi-managed site's FastCGI cache when content changes. Built on the WPForge plugin Foundation.",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=8.2",
        "ext-sodium": "*",
        "psr/container": "^2.0"
    },
    "require-dev": {
        "squizlabs/php_codesniffer": "^3.10",
        "wp-coding-standards/wpcs": "^3.1",
        "dealerdirect/phpcodesniffer-composer-installer": "^1.0",
        "phpstan/phpstan": "^2.0",
        "szepeviktor/phpstan-wordpress": "^2.0",
        "php-stubs/wordpress-stubs": "^6.5",
        "pestphp/pest": "^2.34",
        "brain/monkey": "^2.6"
    },
    "autoload": {
        "psr-4": {
            "WPForge\\": "foundation/src/",
            "WPForge\\Module\\AdminUi\\": "modules/admin-ui/src/",
            "FastCgiCacheForPloi\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "FastCgiCacheForPloi\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true,
        "platform": {
            "php": "8.2"
        },
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "pestphp/pest-plugin": true
        }
    },
    "scripts": {
        "cs": "phpcs",
        "cbf": "phpcbf",
        "stan": "phpstan analyse --memory-limit=1G",
        "test": "pest",
        "qa": [
            "@cs",
            "@stan",
            "@test"
        ]
    },
    "scripts-descriptions": {
        "cs": "Run PHPCS (WordPress Coding Standards + security sniffs).",
        "cbf": "Auto-fix PHPCS violations.",
        "stan": "Run PHPStan at max level with WordPress stubs.",
        "test": "Run the Pest unit suite.",
        "qa": "Run cs + stan + test (full quality gate)."
    }
}
