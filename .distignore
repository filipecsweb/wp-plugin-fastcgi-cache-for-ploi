# Files excluded from the distributed plugin ZIP (wp dist-archive reads this).
# This is the SINGLE source of truth for what the shipped archive omits — there is
# deliberately no second mechanism (no .gitattributes export-ignore) to drift from.
#
# The shipped ZIP = runtime PHP (fastcgi-cache-for-ploi.php, uninstall.php, src/,
# foundation/, modules/, resources/views/) + the production Composer autoloader
# (vendor/, installed with --no-dev) + the built, minified front-end assets
# (public/build/) + the translations template (languages/). The front-end SOURCE
# (resources/js, resources/css) and its build config (vite.config.*, package.json,
# package-lock.json) do NOT ship: the complete human-readable source lives in the
# public GitHub repo, which satisfies the wordpress.org source-availability guideline.
# Everything below is build/test/tooling and must NOT ship.

# --- VCS / CI / OS / editor ---
.git
.gitignore
.distignore
.github
.editorconfig
.nvmrc
.DS_Store

# --- AI / assistant tooling ---
.claude

# --- WordPress.org page assets (banner/icon/screenshots: SVN assets/, never the ZIP) ---
.wordpress-org

# --- Front-end: source and build config are NOT shipped — only the compiled,
# minified public/build/ output ships. The human-readable source lives in the
# public GitHub repo. ---
node_modules
package.json
package-lock.json
vite.config.*
resources/js
resources/css

# --- Composer ---
# composer.json SHIPS: Plugin Check warns (missing_composer_json_file) when a
# composer-managed vendor/ exists without it. The production vendor/ (installed
# with --no-dev) ships too; composer.lock is dev-only and excluded.
composer.lock

# --- Tests & QA tooling ---
tests
phpunit.xml.dist
phpunit.xml
.phpunit.cache
.phpunit.result.cache
phpcs.xml.dist
phpcs.xml
.phpcs.cache
phpstan.neon.dist
phpstan.neon
playwright.config.js
playwright-report
test-results

# --- Documentation & markdown (readme.txt is .txt and is KEPT) ---
docs
*.md

# --- Misc dev-only ---
*.example
public/build/hot
bin
dist
