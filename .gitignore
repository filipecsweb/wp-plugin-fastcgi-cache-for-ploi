# Dependencies
/vendor/
/node_modules/

# Build output (run `composer install && npm install && npm run build`)
/public/build/

# Distributable archive (built into a staging dir; see .distignore)
/dist/

# Generated translation template (regenerate with:
#   wp i18n make-pot . languages/fastcgi-cache-for-ploi.pot --exclude=dist)
/languages/*.pot

# Tooling caches
/.phpunit.cache/
/.phpunit.result.cache
/.phpcs.cache
/phpstan.neon
/phpcs.xml
/phpunit.xml

# Playwright
/test-results/
/playwright-report/
/playwright/.cache/

# Local / OS
.DS_Store
*.log
.idea/
.vscode/
