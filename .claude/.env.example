# WordPress installation under test
WP_BASE_URL=
WP_ADMIN_USER=
WP_ADMIN_PASS=

# Path prefix for installs that nest WordPress under a subdir (e.g. Bedrock
# serves wp-admin at /wp). Leave empty for a standard install.
WP_PATH_PREFIX=

# Absolute path to this plugin's entry in the WP-under-test plugins directory.
# The e2e preflight asserts it resolves to this checkout, so a stale copy of the
# plugin can't be silently tested instead of your working tree.
WP_PLUGIN_PATH=

# Ploi API tokens — one per environment/account.
# Add more by following the PLOI_API_TOKEN_<LABEL> pattern.
PLOI_API_TOKEN_BAD=
PLOI_API_TOKEN_GOOD=
