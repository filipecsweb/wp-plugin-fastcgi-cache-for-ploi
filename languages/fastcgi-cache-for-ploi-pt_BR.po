#: src/Log/FlushLogEntry.php:111
msgid "Ploi rejected the token as wrong or expired."
msgstr "A Ploi rejeitou o token por ser inválido ou expirado."

#: src/Log/FlushLogEntry.php:112
msgid "Ploi could not find the server or site — it may have been deleted."
msgstr "A Ploi não encontrou o servidor ou o site — ele pode ter sido excluído."

#: src/Log/FlushLogEntry.php:113
msgid "Ploi rejected the flush — FastCGI caching may not be enabled for this site."
msgstr "A Ploi rejeitou a limpeza — o cache FastCGI pode não estar habilitado para este site."

#: src/Ploi/PloiApiException.php:28
msgid "Your Ploi API token was rejected. Check the token and try again."
msgstr "Seu token da API da Ploi foi rejeitado. Verifique o token e tente novamente."

#: src/Ploi/PloiApiException.php:35
msgid "This Ploi API token is missing a required permission. Use a token with the Servers and Sites scopes."
msgstr "Este token da API da Ploi não tem uma permissão necessária. Use um token com os escopos Servers e Sites."

#. translators: %d: HTTP status code.
#: src/Ploi/PloiApiException.php:57
#, php-format
msgid "The Ploi API request failed (HTTP %d)."
msgstr "A requisição à API da Ploi falhou (HTTP %d)."

#: src/Providers/AdminServiceProvider.php:80
msgid "Settings saved."
msgstr "Configurações salvas."

#: src/Providers/AdminServiceProvider.php:81
msgid "Connected to Ploi. Now choose a flush target."
msgstr "Conectado à Ploi. Agora escolha um destino de limpeza."

#: src/Providers/AdminServiceProvider.php:82
msgid "Flush target updated."
msgstr "Destino da limpeza atualizado."

#: src/Providers/AdminServiceProvider.php:83
msgid "Token removed. Add a new token to reconnect."
msgstr "Token removido. Adicione um novo token para reconectar."

#: src/Providers/AdminServiceProvider.php:84
msgid "Something went wrong. Please try again."
msgstr "Algo deu errado. Tente novamente."

#: src/Providers/AdminServiceProvider.php:85
msgid "Add a Ploi API token first."
msgstr "Adicione um token da API da Ploi primeiro."

#: src/Providers/AdminServiceProvider.php:90
msgid "Your saved token could not be read — your site's security keys may have changed. Re-enter your Ploi API token and click Connect."
msgstr "Seu token salvo não pôde ser lido — as chaves de segurança do seu site podem ter mudado. Informe novamente seu token da API da Ploi e clique em Conectar."

#: src/Providers/AdminServiceProvider.php:94
msgid "Ploi rejected your saved token. Re-enter a valid Ploi API token and click Connect."
msgstr "A Ploi rejeitou seu token salvo. Informe um token válido da API da Ploi e clique em Conectar."

#: src/Providers/AdminServiceProvider.php:95
msgid "Your saved token is missing a required permission. Re-enter a token with the Servers and Sites scopes and click Connect."
msgstr "Seu token salvo não tem uma permissão necessária. Informe um token com os escopos Servers e Sites e clique em Conectar."

#: src/Providers/AdminServiceProvider.php:101
msgid "Couldn't reach Ploi right now. Try again in a moment."
msgstr "Não foi possível conectar à Ploi agora. Tente novamente em instantes."

#: src/Providers/AdminServiceProvider.php:105
msgid "The saved server no longer exists in Ploi. Choose a new server and site."
msgstr "O servidor salvo não existe mais na Ploi. Escolha um novo servidor e site."

#: src/Providers/AdminServiceProvider.php:106
msgid "The saved site no longer exists in Ploi. Choose another site."
msgstr "O site salvo não existe mais na Ploi. Escolha outro site."

#: src/Rest/ConnectionController.php:81
msgid "Enter a Ploi API token to connect."
msgstr "Informe um token da API da Ploi para conectar."

#: src/Rest/FlushController.php:49
msgid "Add a token, then choose a server and site before flushing."
msgstr "Adicione um token e escolha um servidor e um site antes de limpar o cache."

#: src/Rest/FlushController.php:57
msgid "Nothing to flush — the plugin is not configured."
msgstr "Nada para limpar — o plugin não está configurado."

#: src/Rest/FlushController.php:75
msgid "FastCGI cache flushed."
msgstr "Cache FastCGI limpo."

#: src/Rest/FlushController.php:94
msgid "The flush request failed."
msgstr "A solicitação de limpeza falhou."

