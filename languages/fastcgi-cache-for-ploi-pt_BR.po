#. Plugin Name of the plugin
#: fastcgi-cache-for-ploi.php
#: src/Admin/SettingsPage.php:56
msgid "FastCGI Cache for Ploi"
msgstr "FastCGI Cache for Ploi"

#. Plugin URI of the plugin
#: fastcgi-cache-for-ploi.php
msgid "https://wordpress.org/plugins/fastcgi-cache-for-ploi/"
msgstr "https://wordpress.org/plugins/fastcgi-cache-for-ploi/"

#. Description of the plugin
#: fastcgi-cache-for-ploi.php
msgid "Automatically flush a Ploi-managed site's FastCGI cache when content changes."
msgstr "Limpa automaticamente o cache FastCGI de um site gerenciado pela Ploi quando o conteúdo muda."

#. Author of the plugin
#: fastcgi-cache-for-ploi.php
msgid "Filipe Seabra"
msgstr "Filipe Seabra"

#. Author URI of the plugin
#: fastcgi-cache-for-ploi.php
msgid "https://github.com/filipecsweb"
msgstr "https://github.com/filipecsweb"

#: fastcgi-cache-for-ploi.php:58
msgid "FastCGI Cache for Ploi: dependencies are missing. Run \"composer install\" in the plugin directory."
msgstr "FastCGI Cache for Ploi: as dependências não foram instaladas. Execute \"composer install\" no diretório do plugin."

